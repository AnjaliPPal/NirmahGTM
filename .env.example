# ── Scoring thresholds ────────────────────────────────────────────────────────
SCORE_THRESHOLD=6          # fire alert when score >= this
CONFIDENCE_THRESHOLD=80    # below this → quarantine to #human-review-required
CACHE_DAYS=14              # skip re-scoring if same domain scored within N days

# ── ROI receipt ───────────────────────────────────────────────────────────────
DEAL_ACV=45000             # client's average contract value (for pipeline estimate)

# ── HubSpot CRM (optional — enables auto-push of hot leads as contacts + deals) ──
# Get from: HubSpot → Settings → Integrations → Private Apps → Create private app
# Scopes needed: crm.objects.contacts.write, crm.objects.deals.write, crm.associations.write
HUBSPOT_ACCESS_TOKEN=pat-na1-...
HUBSPOT_PORTAL_ID=         # your HubSpot portal/account ID (in URL: app.hubspot.com/contacts/{id})

# ── Enrichment tier 1-2 (optional free APIs) ──────────────────────────────────
HUNTER_API_KEY=...         # hunter.io — 25 domain lookups/month free
APOLLO_API_KEY=...         # apollo.io — 50 org enrichments/month free

# ── Enrichment tier 3 (self-hosted Firecrawl) ────────────────────────────────
# self-hosted Firecrawl endpoint — run via Docker locally or deploy on Render/Railway free tier
FIRECRAWL_API_URL=http://localhost:3002
