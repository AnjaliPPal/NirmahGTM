# Copy to .env and fill in. Only GROQ_API_KEY is required; everything else is
# optional and degrades gracefully when unset.

# ── Required: Groq (scoring + opener + situation + reply classify) ─────────────
GROQ_API_KEY=gsk_...                  # free tier — console.groq.com

# ── Optional: OpenAI (pre-filter gpt-4o-mini + RAG embeddings) ─────────────────
# Without this, pre-filter falls back to rule-based and RAG retrieval is skipped.
OPENAI_API_KEY=sk-...

# ── Slack alerts ──────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...          # main sales channel
SLACK_REVIEW_WEBHOOK_URL=https://hooks.slack.com/services/...   # #human-review-required

# ── Supabase (Postgres + pgvector) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # preferred over publishable key when set

# ── Scoring thresholds ────────────────────────────────────────────────────────
SCORE_THRESHOLD=6                     # fire alert when score >= this
CONFIDENCE_THRESHOLD=80               # below this -> quarantine to #human-review-required
CACHE_DAYS=28                         # skip re-scoring same domain within N days (Ritu 4-week rule)
DEAL_ACV=45000                        # avg contract value (pipeline estimate in Slack alert)

# ── HubSpot CRM (optional — auto-push hot leads as contacts + deals) ──────────
# Scopes: crm.objects.contacts.write, crm.objects.deals.write, crm.associations.write
HUBSPOT_ACCESS_TOKEN=pat-na1-...
HUBSPOT_PORTAL_ID=

# ── Enrichment (optional free APIs — Hunter -> Apollo -> Firecrawl waterfall) ─
HUNTER_API_KEY=                       # hunter.io — 50 credits/month free
APOLLO_API_KEY=                       # apollo.io — 50 data credits/month free
FIRECRAWL_API_KEY=                    # firecrawl.dev — 500 credits/month free (takes priority)
FIRECRAWL_API_URL=http://localhost:3002   # self-hosted Firecrawl, used only when API_KEY unset

# ── Langfuse LLM observability (optional) ────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── API security ──────────────────────────────────────────────────────────────
WEBHOOK_SECRET=                       # X-Signalos-Webhook-Secret header for /webhook/hubspot-reply
ADMIN_API_KEY=                        # X-Admin-Key header for /admin/failed-inserts
CORS_ORIGINS=                         # comma-separated allowed origins (defaults to *)
